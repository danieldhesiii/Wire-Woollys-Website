# Copy to .env.local and fill in. All are OPTIONAL — the site runs without them
# (reviews/bookings fall back to a local file store; gallery shows a curated grid).

# --- Supabase (persistent reviews + bookings) ---
# Create a project at https://supabase.com, run supabase/schema.sql, then:
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auto-updating gallery (Behold.so) ---
# Create a free feed at https://behold.so, connect the studio's Instagram,
# then paste the feed id here so new posts appear on the site automatically.
NEXT_PUBLIC_BEHOLD_FEED_ID=
